{
  "name": "g5-analytics",
  "version": "1.1.2",
  "description": "Developer-first analytics SDK. Track events, identify users, and analyze behavior.",
  "author": "pankaj-quest",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/pankaj-quest/g5"
  },
  "keywords": ["analytics", "tracking", "events", "mixpanel", "g5"],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "browser": "dist/index.umd.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "rollup -c rollup.config.ts --configPlugin typescript",
    "dev": "rollup -c rollup.config.ts --configPlugin typescript --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-terser": "^0.4.4",
    "rollup": "^4.29.0",
    "typescript": "^5.7.0"
  }
}
